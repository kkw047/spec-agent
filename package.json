{
  "name": "spec-agent",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "npm --prefix frontend run dev",
    "dev:frontend": "npm --prefix frontend run dev",
    "dev:backend": "cd backend && .venv\\Scripts\\python.exe -m uvicorn app.main:app --reload --host 127.0.0.1 --port 8000",
    "build": "npm --prefix frontend run build",
    "lint": "npm --prefix frontend run lint",
    "check:backend": "backend\\.venv\\Scripts\\python.exe -m compileall backend\\app"
  }
}
